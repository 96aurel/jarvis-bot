# Copie ce fichier en .env et remplis les valeurs
TELEGRAM_BOT_TOKEN=ton_token_telegram

# ── LLM : choisis "groq" (gratuit) ou "openai" ──
LLM_PROVIDER=groq

# Groq (gratuit — https://console.groq.com/keys)
GROQ_API_KEY=ta_cle_groq
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (fallback gratuit — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=ta_cle_gemini

# OpenAI (optionnel — seulement si LLM_PROVIDER=openai)
OPENAI_API_KEY=ta_cle_openai
OPENAI_MODEL=gpt-4o-mini

ALLOWED_USER_IDS=123456789
